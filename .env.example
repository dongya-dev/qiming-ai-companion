# ===== 启明AI学习伴侣 - 环境变量配置 =====
# 复制此文件为 .env 并填入实际值

# DeepSeek API Key（必需 - 核心AI功能：阅读简化/思维导图/任务拆解/AI答疑/闪卡/笔记）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# 豆包 TTS 语音合成（可选 - 不配置则语音朗读不可用）
DOUBAO_APP_ID=
DOUBAO_ACCESS_KEY=

# 飞书多维表格云存储（可选 - 不配置则使用本地文件存储）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BASE_TOKEN=

# 认证签名密钥（可选 - 用于Token签名，修改会使所有已登录用户失效）
AUTH_SECRET=qiming_edu_auth_2026_secret_key

# 服务端口（Railway自动设置，本地开发默认3000）
PORT=3000
